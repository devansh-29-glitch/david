{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "David",
  "version": "1.0.0",
  "identifier": "com.neuramindlabs.david",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "orb",
        "title": "David",
        "url": "orb.html",
        "width": 56,
        "height": 56,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": true,
        "resizable": false,
        "skipTaskbar": true,
        "x": 1820,
        "y": 400,
        "shadow": false
      },
      {
        "label": "auth",
        "title": "David — Sign in",
        "url": "auth.html",
        "width": 420,
        "height": 540,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "David"
    },
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist"
    },
    "resources": [
      "resources/models/*"
      
    ]
  }
}
